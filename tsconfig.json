{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/shared/src/*"],
      "@app/*": ["apps/client/src/*"],
      "@assets/*": ["apps/client/assets/*"]
    },
    "types": ["nativewind/types", "jest"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
