{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../packages/shared/src/*"],
      "@app/*": ["src/*"],
      "@assets/*": ["assets/*"]
    },
    "types": ["nativewind/types", "jest"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "../../packages/shared/src/**/*.ts",
    "../../packages/shared/src/**/*.tsx"
  ]
}
