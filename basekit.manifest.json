  "features": {
    "auth": {
      "displayName": "Authentication",
      "description": "User sign-in, sign-up, password reset, and session management",
      "category": "auth",
      "providers": {
        "amplify": {
          "files": [
            "src/features/auth/providers/amplify.ts",
            "src/lib/amplify/configure.ts"
          ],
          "dependencies": {
            "aws-amplify": "^6.16.3",
            "@aws-amplify/react-native": "^1.3.3",
            "amazon-cognito-identity-js": "^6.3.16"
          },
          "envVars": {
            "required": [
              "EXPO_PUBLIC_COGNITO_USER_POOL_ID",
              "EXPO_PUBLIC_COGNITO_CLIENT_ID"
            ],
            "optional": [
              "EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID"
            ]
          }
        }
      },
      "sharedFiles": [
        "src/features/auth/auth-context.ts",
        "src/features/auth/auth-provider.tsx",
        "src/features/auth/create-auth-service.ts",
        "src/features/auth/hooks/use-auth.ts",
        "src/features/auth/hooks/use-current-user.ts",
        "src/features/auth/hooks/use-session.ts",
        "src/features/auth/index.ts",
        "src/features/auth/no-op-auth.ts",
        "src/features/auth/__tests__/create-auth-service.test.ts",
        "src/features/auth/__tests__/no-op-auth.test.ts"
      ],
      "sharedDependencies": {},
      "requires": [],
      "enhancedBy": ["analytics", "crash-reporting"],
      "providerChain": {
        "component": "AuthProvider",
        "import": "@/features/auth",
        "order": 50
      },
      "routes": [
        "src/app/(auth)/"
      ]
    },
